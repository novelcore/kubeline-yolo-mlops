# Environment variables for the Dataset Loading step
# Copy this file to .env and fill in the values for your environment.

# ---------------------------------------------------------------------------
# Application settings
# ---------------------------------------------------------------------------
APP_NAME=io-dataset-loading
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
MAX_RETRIES=3           # Number of S3/LakeFS request retries
TIMEOUT=120             # Request timeout in seconds

# ---------------------------------------------------------------------------
# AWS / S3 connection settings
# (Leave unset to rely on the instance IAM role or default AWS credential chain)
# ---------------------------------------------------------------------------
AWS_DEFAULT_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=<your-access-key-id>
# AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
# S3_ENDPOINT_URL=https://minio.example.com   # Only needed for non-AWS S3 endpoints

# ---------------------------------------------------------------------------
# LakeFS connection settings (S3-compatible API)
# Set these when --source lakefs is used.
# ---------------------------------------------------------------------------
# LAKEFS_ENDPOINT=https://lakefs.example.com
# LAKEFS_ACCESS_KEY=<your-lakefs-access-key-id>
# LAKEFS_SECRET_KEY=<your-lakefs-secret-access-key>

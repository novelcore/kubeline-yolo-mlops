# Environment variables for the Config Validation step
# Copy this file to .env and modify as needed

# Application settings
APP_NAME=io-config-validation
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT=30

# Validation settings
STRICT_MODE=true

# Liveness checks (set to true for local runs or CI without live infrastructure)
SKIP_LIVENESS_CHECKS=false

# MLflow tracking server URI (required when SKIP_LIVENESS_CHECKS=false)
MLFLOW_TRACKING_URI=http://mlflow.example.com

# AWS / S3 credentials (used when dataset.source = "s3")
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-central-1
# S3_ENDPOINT_URL=https://minio.example.com   # Only for non-AWS S3 endpoints

# LakeFS connection settings (used when dataset.source = "lakefs")
# LAKEFS_ENDPOINT=http://localhost:8000
# LAKEFS_ACCESS_KEY=<your-lakefs-access-key-id>
# LAKEFS_SECRET_KEY=<your-lakefs-secret-access-key>

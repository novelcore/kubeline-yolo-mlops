# Environment variables for the Config Validation step
# Copy this file to .env and modify as needed

# Application settings
APP_NAME=io-config-validation
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT=30

# Validation settings
STRICT_MODE=true

# Liveness checks (set to true for local runs or CI without live infrastructure)
SKIP_LIVENESS_CHECKS=false

# MLflow tracking server URI (required when SKIP_LIVENESS_CHECKS=false)
MLFLOW_TRACKING_URI=http://mlflow.example.com

# AWS credentials are read automatically by boto3 from the environment.
# Set these if not using IAM roles or ~/.aws/credentials:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-central-1

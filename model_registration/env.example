# Environment variables for the Model Registration step.
# Copy this file to .env and fill in the required values.

# ---- Application settings ----
APP_NAME=io-model-registration
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT=60

# ---- MLflow (required) ----
MLFLOW_TRACKING_URI=http://mlflow.example.com:5000
MLFLOW_EXPERIMENT_NAME=infinite-orbits
REGISTERED_MODEL_NAME=spacecraft-pose-yolo

# ---- AWS / S3 credentials ----
# Used by boto3 when resolving S3 checkpoint URIs.
# Standard boto3 environment variables — no need to add them to Config.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
# Optional: set when using MinIO or a custom S3-compatible endpoint
# AWS_ENDPOINT_URL=http://minio.example.com:9000

# Environment variables for the Model Registration step.
# Copy this file to .env and fill in the required values.

# ---- Application settings ----
APP_NAME=io-model-registration
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT=60

# ---- MLflow (required) ----
MLFLOW_TRACKING_URI=http://mlflow.example.com:5000
# MLFLOW_TRACKING_USERNAME=admin
# MLFLOW_TRACKING_PASSWORD=changeme
MLFLOW_EXPERIMENT_NAME=infinite-orbits
REGISTERED_MODEL_NAME=spacecraft-pose-yolo

# ---- AWS / S3 credentials ----
# Used by boto3 when resolving S3 checkpoint URIs.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_ENDPOINT_URL=http://minio.example.com:9000

# ---- LakeFS connection settings ----
# LAKEFS_ENDPOINT=http://localhost:8000
# LAKEFS_ACCESS_KEY=<your-lakefs-access-key-id>
# LAKEFS_SECRET_KEY=<your-lakefs-secret-access-key>
